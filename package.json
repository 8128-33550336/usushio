    "punycode": "2.3.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6",
    "@types/node": "^26.1.0",
    "@types/punycode": "^2.1.4",
    "typescript": "^6.0.3"
  }
}
